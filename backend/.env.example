OPENAI_API_KEY=your_openai_key_here
TAVILY_API_KEY=your_tavily_key_here

# Model Configuration (optional)
# OPENAI_MODEL=gpt-4o-mini
# PLANNER_MODEL=gpt-4o-mini
# RESEARCHER_MODEL=gpt-4o-mini
# ANALYST_MODEL=gpt-4o-mini
# SYNTHESIZER_MODEL=gpt-4o-mini
# CRITIC_MODEL=gpt-4o-mini

# Search Settings (optional)
# MAX_SEARCH_RESULTS=5
# MAX_ARXIV_RESULTS=3
# SEARCH_DEPTH=advanced

# Content Settings (optional)
# MAX_CONTENT_LENGTH=5000
# MIN_CREDIBILITY_SCORE=0.3

# Research Settings (optional)
# MIN_SUB_QUESTIONS=3
# MAX_SUB_QUESTIONS=5
# MIN_SOURCES_PER_QUESTION=3

# Temperature Settings (optional)
# PLANNER_TEMPERATURE=0.7
# RESEARCHER_TEMPERATURE=0.3
# ANALYST_TEMPERATURE=0.3
# SYNTHESIZER_TEMPERATURE=0.5
# CRITIC_TEMPERATURE=0.3

# CORS Settings (optional)
# CORS_ORIGINS=http://localhost:3000
